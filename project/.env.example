# StreamVault Frontend - Variables de Entorno
# ===========================================
# Copiar este archivo a .env y completar con valores reales
# NO commitear .env con credenciales reales

# ===========================================
# CONFIGURACIÓN PRINCIPAL
# ===========================================

# URL del backend API (obligatoria)
# Formato: http://<host>:<puerto>/api/v1
# Ejemplo para desarrollo local: http://localhost:8080/api/v1
# Ejemplo para producción: https://api.streamvault.com/api/v1
API_URL=http://localhost:8080/api/v1

# URL del WebSocket server (para notificaciones en tiempo real)
# Formato: ws://<host>:<puerto>/ws
# Ejemplo para desarrollo local: ws://localhost:8080/ws
# Ejemplo para producción: wss://api.streamvault.com/ws
WS_URL=ws://localhost:8080/ws

# URL del servidor MinIO/S3 (para thumbnails y recursos estáticos)
# Ejemplo: http://localhost:9000
MINIO_URL=http://localhost:9000

# ===========================================
# CONFIGURACIÓN DE PUERTOS (no suelen requerir cambios)
# ===========================================

# Puerto donde sirve el contenedor (80 = HTTP, 443 = HTTPS)
# FRONTEND_PORT=80
