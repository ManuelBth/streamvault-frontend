# StreamVault - Configuración de Producción
# Copiar este archivo a .env y editar los valores

# ============================================
# ENDPOINTS - Cambiar según tu infraestructura
# ============================================

# URL del API backend
API_URL=http://localhost:8080/api/v1

# WebSocket URL para tiempo real
WS_URL=ws://localhost:8080/ws

# URL de MinIO para thumbnails
MINIO_URL=http://localhost:9000

# ============================================
# REPOSITORIO - Imagen de Docker
# ============================================

# Formato: usuario/proyecto
# Ejemplo: ghcr.io/manuelbth/streamvault
IMAGE_REPO=manuelbth/streamvault